<UserControl x:Class="Ascend.MVVM.View.Neptune7View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Ascend.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" 
             d:DesignWidth="800"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="RoundedAITextBoxStyle" 
               TargetType="TextBox">
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="BorderThickness" 
                    Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                CornerRadius="15"
                                BorderThickness="1.5"
                                Background="{TemplateBinding Background}">
                            <Border.BorderBrush>
                                <LinearGradientBrush x:Name="borderBrush"
                                                     StartPoint="0,0"
                                                     EndPoint="0,1">
                                    <!--Initial: Rahmen startet in der Mitte-->
                                    <GradientStop x:Name="topStop" 
                                                  Color="#BEBEBE" 
                                                  Offset="0.5"/>
                                    <GradientStop x:Name="middleStop" 
                                                  Color="#BEBEBE" 
                                                  Offset="0.5"/>
                                    <GradientStop x:Name="bottomStop" 
                                                  Color="Transparent" 
                                                  Offset="0.5"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>

                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="5" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <!--Hover: Rahmen fließt nach oben und unten-->
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="topStop"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.0"
                                                             Duration="0:0:0.6"
                                                             FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="middleStop"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="1.0"
                                                             Duration="0:0:0.6"
                                                             FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="bottomStop"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="1.0"
                                                             Duration="0:0:0.6"
                                                             FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <!--Verlassen: Rahmen fließt zurück zur Mitte-->
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="topStop"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.5"
                                                             Duration="0:0:0.6"
                                                             FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="middleStop"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.5"
                                                             Duration="0:0:0.6"
                                                             FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="bottomStop"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.5"
                                                             Duration="0:0:0.6"
                                                             FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedAIButton" 
               TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                CornerRadius="15" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="border" 
                                        Property="Background" 
                                        Value="#2a2a4d"/>
                            </Trigger>
                            <Trigger Property="IsPressed" 
                                     Value="True">
                                <Setter TargetName="border" 
                                        Property="Background" 
                                        Value="#303057"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border CornerRadius="10"               
            Padding="20"
            Margin="0"
            SnapsToDevicePixels="True">

        <!--Hintergrundbild per ImageBrush-->
        <Border.Background>
            <ImageBrush ImageSource="/Icons/AIBackgroundNew.jpg"
                        Stretch="UniformToFill"
                        AlignmentX="Center"
                        AlignmentY="Top"/>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--Image oben-->
            <!--
            <Image Grid.Row="0"
                   Source="/Icons/NXOTest2.jpg"
                   Height="330"
                   Width="330"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="Fant"
                   Margin="0,50,0,20"/>
            -->

            <!--Inhalt-->
            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,150,0,0">
                <TextBlock Text="How can I help you?" 
                           HorizontalAlignment="Center" 
                           FontSize="20" 
                           FontWeight="Bold"
                           Foreground="White"/>

                <Grid HorizontalAlignment="Center" 
                      Margin="6,10,0,20">
                    <!--Suchfeld-->
                    <TextBox x:Name="FriendInput"
                             Width="334"
                             Height="34"
                             Padding="10,0,35,0" 
                             VerticalContentAlignment="Center"
                             Foreground="White"
                             BorderThickness="1.5"
                             BorderBrush="#BEBEBE"
                             Style="{StaticResource RoundedAITextBoxStyle}">
                        <TextBox.Background>
                            <LinearGradientBrush StartPoint="0,0" 
                                                 EndPoint="0,1">
                                <GradientStop Color="Transparent" 
                                              Offset="0.0"/>
                                <GradientStop Color="Transparent" 
                                              Offset="1.0"/>
                            </LinearGradientBrush>
                        </TextBox.Background>
                    </TextBox>

                    <!--Button innerhalb der TextBox-->
                    <Button Content="➤"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            Cursor="Hand"
                            FontSize="16"/>
                </Grid>

                <TextBlock Text="Powered by OpenAI" 
                           HorizontalAlignment="Center" 
                           FontSize="11" 
                           Foreground="#BEBEBE"
                           Margin="220,-20,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
