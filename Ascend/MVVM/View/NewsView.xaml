<UserControl x:Class="Ascend.MVVM.View.NewsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wpfAnimatedGif="http://wpfanimatedgif.codeplex.com"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="Transparent"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <Style x:Key="NavigateButton" 
               TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                CornerRadius="15" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="border" 
                                        Property="Background" 
                                        Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="border" 
                                        Property="Background" 
                                        Value="#2d2d52"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!--Abgerundeter Container-->
    <Border CornerRadius="10"
            ClipToBounds="True"
            SnapsToDevicePixels="True">

        <!--Hintergrundbild per ImageBrush-->
        <Border.Background>
            <ImageBrush ImageSource="/Icons/NewsBackgroundTest2.jpg"
                        Stretch="UniformToFill"
                        AlignmentX="Center"
                        AlignmentY="Top"/>
        </Border.Background>

        <!--Scrollbarer Inhalt-->
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly"
                      Background="Transparent">
            <StackPanel Margin="20">

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Stretch" 
                            Margin="0,10,0,152">
                    <TextBlock FontSize="31"
                               FontFamily="Super Comic"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Margin="335,0,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black"
                                              Direction="320"
                                              ShadowDepth="3"
                                              Opacity="0.7"
                                              BlurRadius="12"/>
                        </TextBlock.Effect>

                          <Run Text="Thank you"/>
                          <LineBreak/>
                          <Run Text="for using Ascend."/>
                          <LineBreak/>
                          <Run Text="You're amazing!"/>
                    </TextBlock>

                    <!--
                    <Image x:Name="AnimatedGif"
                           Width="175"
                           Height="175"
                           VerticalAlignment="Center"
                           Margin="170,0,0,0"
                           Stretch="Uniform"/>
                     -->
                </StackPanel>

                <TextBlock Text="WHAT'S NEW?"
                           FontSize="25"
                           FontFamily="Super Comic"
                           Foreground="White"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black"
                                          Direction="320"
                                          ShadowDepth="3"
                                          Opacity="0.7"
                                          BlurRadius="12"/>
                    </TextBlock.Effect>
                </TextBlock>

