                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <ColorAnimation Storyboard.TargetName="leftStop1" 
                                                    Storyboard.TargetProperty="Color" 
                                                    To="#303057" 
                                                    Duration="0:0:0.5"/>
                                    <ColorAnimation Storyboard.TargetName="rightStop1" 
                                                    Storyboard.TargetProperty="Color" 
                                                    To="#303057" 
                                                    Duration="0:0:0.5"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Grid.Triggers>
