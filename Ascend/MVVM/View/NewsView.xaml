                                    Width="100"
                                    Height="30"
                                    FontSize="14"
                                    Background="Transparent"
                                    Foreground="White"
                                    BorderThickness="1"
                                    BorderBrush="White"
                                    Cursor="Hand"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource NavigateButton}"/>
                        </StackPanel>
                    </Border>
                    <!--Trigger-->
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Grid.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTransform1" 
                                                     Storyboard.TargetProperty="ScaleX" 
                                                     To="1.05" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTransform1" 
                                                     Storyboard.TargetProperty="ScaleY" 
                                                     To="1.05" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect1" 
                                                     Storyboard.TargetProperty="BlurRadius" 
                                                     To="24" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect1" 
                                                     Storyboard.TargetProperty="Opacity" 
                                                     To="0.6" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="brushTransform1" 
                                                     Storyboard.TargetProperty="X" 
                                                     From="0" 
                                                     To="1" 
                                                     Duration="0:0:2" 
                                                     AutoReverse="True" 
                                                     RepeatBehavior="Forever">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <ColorAnimation Storyboard.TargetName="leftStop1" 
                                                    Storyboard.TargetProperty="Color" 
                                                    From="#303057" 
                                                    To="White" 
                                                    Duration="0:0:2" 
                                                    AutoReverse="True" 
                                                    RepeatBehavior="Forever"/>
                                    <ColorAnimation Storyboard.TargetName="rightStop1" 
                                                    Storyboard.TargetProperty="Color" 
                                                    From="#303057" 
                                                    To="White" 
                                                    Duration="0:0:2" 
                                                    AutoReverse="True" 
                                                    RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
