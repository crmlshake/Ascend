                                                    Duration="0:0:0.5"/>
                                    <ColorAnimation Storyboard.TargetName="rightStop4" 
                                                    Storyboard.TargetProperty="Color" 
                                                    To="#303057" 
                                                    Duration="0:0:0.5"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Grid.Triggers>
                </Grid>

                <TextBlock Text="COMING SOON"
                           FontSize="25"
                           FontFamily="Super Comic"
                           Foreground="White"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,140,0,0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black"
                                          Direction="320"
                                          ShadowDepth="3"
                                          Opacity="0.7"
                                          BlurRadius="12"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!--Tab 5-->
                <Grid Width="600"
                      Height="240"
                      Margin="10"
                      RenderTransformOrigin="0.5,0">
                    <!--Skalierung-->
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="scaleTransform5" 
                                        ScaleX="1" 
                                        ScaleY="1"/>
                    </Grid.RenderTransform>
                    <!--Schatten-->
                    <Grid.Effect>
                        <DropShadowEffect x:Name="shadowEffect5" 
                                          BlurRadius="20" 
                                          ShadowDepth="0" 
                                          Opacity="0.8"/>
                    </Grid.Effect>

                    <!--Äußerer Rand mit animiertem Gradient-->
                    <Border CornerRadius="17" 
                            BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush x:Name="animatedGradient5" 
                                                 StartPoint="0,0" 
                                                 EndPoint="1,0">
                                <LinearGradientBrush.RelativeTransform>
                                    <TranslateTransform x:Name="brushTransform5" 
                                                        X="0"/>
                                </LinearGradientBrush.RelativeTransform>
                                <GradientStop x:Name="leftStop5" 
                                              Color="#303057" 
                                              Offset="0"/>
                                <GradientStop x:Name="rightStop5" 
                                              Color="#303057" 
                                              Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                    </Border>

                    <!--Innerer Inhalt-->
                    <Border Width="596"
                            Height="236"
                            CornerRadius="15">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" 
                                                 EndPoint="0,1">
                                <GradientStop Color="#272747" 
                                              Offset="0"/>
                                <GradientStop Color="#161629" 
                                              Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="12,0,10,85">
                            <TextBlock Text="Placeholder"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="No data yet…"
                                       FontSize="14"
                                       Foreground="#BEBEBE"
                                       Margin="0,5,0,10"/>
                            <Button Content="Navigate"
                                    HorizontalAlignment="Left"
                                    Width="100"
                                    Height="30"
                                    FontSize="14"
                                    Background="Transparent"
                                    Foreground="White"
                                    BorderThickness="1"
                                    BorderBrush="White"
                                    Cursor="Hand"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource NavigateButton}"/>
                        </StackPanel>
                    </Border>

                    <!--Trigger-->
                    <Grid.Triggers>
                        <!--MouseEnter-->
                        <EventTrigger RoutedEvent="Grid.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <!--Scale-->
                                    <DoubleAnimation Storyboard.TargetName="scaleTransform5" 
                                                     Storyboard.TargetProperty="ScaleX" 
                                                     To="1.05" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTransform5" 
                                                     Storyboard.TargetProperty="ScaleY" 
                                                     To="1.05" 
                                                     Duration="0:0:0.25"/>
                                    <!--Shadow-->
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect5" 
                                                     Storyboard.TargetProperty="BlurRadius" 
                                                     To="24" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect5" 
                                                     Storyboard.TargetProperty="Opacity" 
                                                     To="0.6" 
                                                     Duration="0:0:0.25"/>
                                    <!--Gradient bewegen-->
                                    <DoubleAnimation Storyboard.TargetName="brushTransform5" 
                                                     Storyboard.TargetProperty="X" 
                                                     From="0" 
                                                     To="1" 
                                                     Duration="0:0:2" 
                                                     AutoReverse="True" 
                                                     RepeatBehavior="Forever">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <!--Farben atmen-->
                                    <ColorAnimation Storyboard.TargetName="leftStop5" 
                                                    Storyboard.TargetProperty="Color" 
                                                    From="#303057" 
                                                    To="White" 
                                                    Duration="0:0:2" 
                                                    AutoReverse="True" 
                                                    RepeatBehavior="Forever"/>
                                    <ColorAnimation Storyboard.TargetName="rightStop5" 
                                                    Storyboard.TargetProperty="Color" 
                                                    From="#303057" 
                                                    To="White" 
                                                    Duration="0:0:2" 
                                                    AutoReverse="True" 
                                                    RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!--MouseLeave-->
                        <EventTrigger RoutedEvent="Grid.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <!--Scale zurück-->
                                    <DoubleAnimation Storyboard.TargetName="scaleTransform5" 
                                                     Storyboard.TargetProperty="ScaleX" 
                                                     To="1" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTransform5" 
                                                     Storyboard.TargetProperty="ScaleY" 
                                                     To="1" 
                                                     Duration="0:0:0.25"/>
                                    <!--Shadow zurück-->
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect5" 
                                                     Storyboard.TargetProperty="BlurRadius" 
                                                     To="20" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect5" 
                                                     Storyboard.TargetProperty="Opacity" 
                                                     To="0.8" 
                                                     Duration="0:0:0.25"/>
                                    <!--Gradient zurücksetzen-->
                                    <DoubleAnimation Storyboard.TargetName="brushTransform5" 
                                                     Storyboard.TargetProperty="X" 
                                                     To="0" 
                                                     Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <!--Farben zurück-->
                                    <ColorAnimation Storyboard.TargetName="leftStop5" 
                                                    Storyboard.TargetProperty="Color" 
                                                    To="#303057" 
                                                    Duration="0:0:0.5"/>
                                    <ColorAnimation Storyboard.TargetName="rightStop5" 
                                                    Storyboard.TargetProperty="Color" 
                                                    To="#303057" 
                                                    Duration="0:0:0.5"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Grid.Triggers>
                </Grid>

            </StackPanel>
        </ScrollViewer>

    </Border>
</UserControl>