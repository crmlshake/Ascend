                <Grid Width="600"
                      Height="240"
                      Margin="10"
                      RenderTransformOrigin="0.5,0">
                    <!--Skalierung-->
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="scaleTransform1" 
                                        ScaleX="1" 
                                        ScaleY="1"/>
                    </Grid.RenderTransform>
                    <!--Shadow-->
                    <Grid.Effect>
                        <DropShadowEffect x:Name="shadowEffect1" 
                                          BlurRadius="20" 
                                          ShadowDepth="0" 
                                          Opacity="0.8"/>
                    </Grid.Effect>
                    <!--Äußerer Rand-->
                    <Border CornerRadius="17" 
                            BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush x:Name="animatedGradient1" 
                                                 StartPoint="0,0" 
                                                 EndPoint="1,0">
                                <LinearGradientBrush.RelativeTransform>
                                    <TranslateTransform x:Name="brushTransform1" 
                                                        X="0"/>
                                </LinearGradientBrush.RelativeTransform>
                                <GradientStop x:Name="leftStop1" 
                                              Color="#303057" 
                                              Offset="0"/>
                                <GradientStop x:Name="rightStop1" 
                                              Color="#303057" 
                                              Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                    </Border>
                    <!--Innerer Inhalt-->
                    <Border Width="596" 
                            Height="236" 
                            CornerRadius="15">
