                                       Foreground="#BEBEBE"
                                       Margin="0,5,0,10">
                                  <Run Text="Looking for more motivation"/>
                                  <LineBreak/>
                                  <Run Text="and even more XP? Try NXO."/>
                                  <LineBreak/>
                                  <Run Text="Based on your previous"/>
                                  <LineBreak/>
                                  <Run Text="to-dos, new ones will be"/>
                                  <LineBreak/>
                                  <Run Text="generated, tailored to"/>
                                  <LineBreak/>
                                  <Run Text="your needs."/>
