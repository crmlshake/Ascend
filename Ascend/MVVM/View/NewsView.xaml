                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTransform4" 
                                                     Storyboard.TargetProperty="ScaleY" 
                                                     To="1.05" 
                                                     Duration="0:0:0.25"/>
                                    <!--Shadow-->
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect4" 
                                                     Storyboard.TargetProperty="BlurRadius" 
                                                     To="24" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect4" 
                                                     Storyboard.TargetProperty="Opacity" 
                                                     To="0.6" 
                                                     Duration="0:0:0.25"/>
                                    <!--Gradient bewegen-->
                                    <DoubleAnimation Storyboard.TargetName="brushTransform4" 
                                                     Storyboard.TargetProperty="X" 
                                                     From="0" 
                                                     To="1" 
                                                     Duration="0:0:2" 
                                                     AutoReverse="True" 
                                                     RepeatBehavior="Forever">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <!--Farben atmen-->
                                    <ColorAnimation Storyboard.TargetName="leftStop4" 
                                                    Storyboard.TargetProperty="Color" 
                                                    From="#303057" 
                                                    To="White" 
                                                    Duration="0:0:2" 
                                                    AutoReverse="True" 
                                                    RepeatBehavior="Forever"/>
                                    <ColorAnimation Storyboard.TargetName="rightStop4" 
                                                    Storyboard.TargetProperty="Color" 
                                                    From="#303057" 
                                                    To="White" 
                                                    Duration="0:0:2" 
                                                    AutoReverse="True" 
                                                    RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!--MouseLeave-->
                        <EventTrigger RoutedEvent="Grid.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <!--Scale zurück-->
                                    <DoubleAnimation Storyboard.TargetName="scaleTransform4" 
                                                     Storyboard.TargetProperty="ScaleX" 
                                                     To="1" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTransform4" 
                                                     Storyboard.TargetProperty="ScaleY" 
                                                     To="1" 
                                                     Duration="0:0:0.25"/>
                                    <!--Shadow zurück-->
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect4" 
                                                     Storyboard.TargetProperty="BlurRadius" 
                                                     To="20" 
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="shadowEffect4" 
                                                     Storyboard.TargetProperty="Opacity" 
                                                     To="0.8" 
                                                     Duration="0:0:0.25"/>
                                    <!--Gradient zurücksetzen-->
                                    <DoubleAnimation Storyboard.TargetName="brushTransform4" 
                                                     Storyboard.TargetProperty="X" 
                                                     To="0" 
                                                     Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
