<UserControl x:Class="Ascend.MVVM.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Ascend.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" 
             d:DesignWidth="800"
             Background="Transparent">

    <Border Background="Transparent" 
            Padding="0">

        <Grid Background="Transparent">

            <!--Vertikales Layout-->
            <StackPanel VerticalAlignment="Top" 
                        HorizontalAlignment="Center">

                <!--Großer, oberer Tab-->
                <Border Width="600"
                        Height="150"
                        CornerRadius="20"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,20"
                        SnapsToDevicePixels="True">
                    <Border.Background>
                        <ImageBrush ImageSource="/Icons/HomeImageTest2.jpg" 
                                    Stretch="Fill"
                                    RenderOptions.BitmapScalingMode="Fant"/>
                    </Border.Background>


                </Border>

                <Label Content="Overview"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="16"
                       Margin="22,-5,0,-5"/>

                <!--Vier kleinere Tabs darunter – WrapPanel für zwei pro Zeile-->
                <WrapPanel Orientation="Horizontal" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,0">

                    <!--Tab 1-->
                    <Grid Width="264" 
                          Height="154" 
                          Margin="10" 
                          RenderTransformOrigin="0.5,0">
                        <!--Gemeinsame Skalierung-->
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="scaleTransform1" 
                                            ScaleX="1" 
                                            ScaleY="1"/>
                        </Grid.RenderTransform>
                        <!--Gesamteffekt (Shadow auf alles)-->
                        <Grid.Effect>
                            <DropShadowEffect x:Name="shadowEffect1" 
                                              BlurRadius="20" 
                                              ShadowDepth="0" 
                                              Opacity="0.8"/>
                        </Grid.Effect>
                        <!--Äußerer Rand mit Verlauf-->
                        <Border CornerRadius="17" 
                                BorderThickness="1.5">
                            <Border.BorderBrush>
                                <LinearGradientBrush x:Name="animatedGradient1" 
                                                     StartPoint="0,0" 
                                                     EndPoint="1,0">
                                    <LinearGradientBrush.RelativeTransform>
                                        <TranslateTransform x:Name="brushTransform1" 
                                                            X="0"/>
                                    </LinearGradientBrush.RelativeTransform>
                                    <!--GradientStops: beide erstmal Grau-->
                                    <GradientStop x:Name="leftStop1" 
                                                  Color="#303057" 
                                                  Offset="0"/>
                                    <GradientStop x:Name="rightStop1" 
                                                  Color="#303057" 
                                                  Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                        </Border>
                        <!--Innerer Inhalt-->
                        <Border Width="260" 
                                Height="150" 
                                CornerRadius="15">
                            <Border.Background>
                                <ImageBrush ImageSource="/Icons/Tab01.jpg" 
                                            Stretch="Fill" 
                                            RenderOptions.BitmapScalingMode="Fant"/>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" 
                                        HorizontalAlignment="Left">
                                <TextBlock Text="To-dos" 
                                           Foreground="White" 
                                           FontWeight="Bold" 
                                           Margin="10,78,0,0" 
                                           FontSize="13"/>
                                <TextBlock Text="Create to-dos!" 
                                           Foreground="#BEBEBE" 
                                           FontSize="12" 
                                           Margin="10,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <!--Trigger-->
                        <Grid.Triggers>
                            <!--MouseEnter-->
                            <EventTrigger RoutedEvent="Grid.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--Scale-->
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform1" 
                                                         Storyboard.TargetProperty="ScaleX" 
                                                         To="1.05" 
                                                         Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform1" 
                                                         Storyboard.TargetProperty="ScaleY" 
                                                         To="1.05" 
                                                         Duration="0:0:0.25"/>
                                        <!--Shadow-->
                                        <DoubleAnimation Storyboard.TargetName="shadowEffect1" 
                                                         Storyboard.TargetProperty="BlurRadius" 
                                                         To="24" 
                                                         Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="shadowEffect1" 
                                                         Storyboard.TargetProperty="Opacity" 
                                                         To="0.6" 
                                                         Duration="0:0:0.25"/>
                                        <!--Gradient verschieben (leichtes Wabern)-->
                                        <DoubleAnimation Storyboard.TargetName="brushTransform1" 
                                                         Storyboard.TargetProperty="X" 
                                                         From="0" 
                                                         To="1" 
                                                         Duration="0:0:2" 
                                                         AutoReverse="True" 
                                                         RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!--Linke Farbe atmet-->
                                        <ColorAnimation Storyboard.TargetName="leftStop1" 
                                                        Storyboard.TargetProperty="Color" 
                                                        From="#303057" 
                                                        To="White" 
                                                        Duration="0:0:2" 
                                                        AutoReverse="True" 
                                                        RepeatBehavior="Forever"/>
                                        <!--Rechte Farbe atmet mit-->
                                        <ColorAnimation Storyboard.TargetName="rightStop1" 
                                                        Storyboard.TargetProperty="Color" 
                                                        From="#303057" 
                                                        To="White" 
                                                        Duration="0:0:2" 
                                                        AutoReverse="True" 
                                                        RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <!--MouseLeave-->
                            <EventTrigger RoutedEvent="Grid.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--Scale zurück-->
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform1" 
                                                         Storyboard.TargetProperty="ScaleX" 
                                                         To="1" 
                                                         Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform1" 
                                                         Storyboard.TargetProperty="ScaleY" 
                                                         To="1" 
                                                         Duration="0:0:0.25"/>
                                        <!--Shadow zurück-->
                                        <DoubleAnimation Storyboard.TargetName="shadowEffect1" 
                                                         Storyboard.TargetProperty="BlurRadius" 
                                                         To="20" 
                                                         Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="shadowEffect1" 
                                                         Storyboard.TargetProperty="Opacity" 
                                                         To="0.8" 
                                                         Duration="0:0:0.25"/>
                                        <!--Gradient zurücksetzen-->
                                        <DoubleAnimation Storyboard.TargetName="brushTransform1" 
                                                         Storyboard.TargetProperty="X" 
                                                         To="0" 
                                                         Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!--Farbe zurück auf Grau-->
                                        <ColorAnimation Storyboard.TargetName="leftStop1" 
                                                        Storyboard.TargetProperty="Color" 
                                                        To="#303057" 
                                                        Duration="0:0:0.5"/>
                                        <ColorAnimation Storyboard.TargetName="rightStop1" 
                                                        Storyboard.TargetProperty="Color" 
                                                        To="#303057" 
                                                        Duration="0:0:0.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>
                    </Grid>

