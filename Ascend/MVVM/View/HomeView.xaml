                                                        Duration="0:0:0.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>
                    </Grid>

                </WrapPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>