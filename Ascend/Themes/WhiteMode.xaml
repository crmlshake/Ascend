<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--IN BEARBEITUNG!-->
    
    <!--Helle Farben für WhiteMode-->
    <Color x:Key="WindowBackgroundTop">#FFFFFF</Color>
    <Color x:Key="WindowBackgroundBottom">#F2F2F2</Color>
    <Color x:Key="TextColor">#000000</Color>
    <Color x:Key="AccentLight">#EAEAEA</Color>
    <Color x:Key="AccentHover">#D6D6D6</Color>
    <Color x:Key="AccentPressed">#C0C0C0</Color>
    <Color x:Key="SearchBoxBackground">#F5F5F5</Color>
    <Color x:Key="SidebarBackground">#DDDDDD</Color>
    <Color x:Key="TitleBarForeground">#000000</Color>
    <Color x:Key="ToggleButtonForeground">#000000</Color>

    <!--Brushes-->
    <SolidColorBrush x:Key="WindowBackgroundTopBrush" Color="{StaticResource WindowBackgroundTop}" />
    <SolidColorBrush x:Key="WindowBackgroundBottomBrush" Color="{StaticResource WindowBackgroundBottom}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLight}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressed}" />
    <SolidColorBrush x:Key="SearchBoxBackgroundBrush" Color="{StaticResource SearchBoxBackground}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackground}" />
    <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="{StaticResource TitleBarForeground}" />
    <SolidColorBrush x:Key="ToggleButtonForegroundBrush" Color="{StaticResource ToggleButtonForeground}" />

    <!--Globale Textfarben-->
    <Style TargetType="Window">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Background" Value="{StaticResource SearchBoxBackgroundBrush}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <!--WhiteMode: RoundedToggleButton-->
    <Style x:Key="RoundedToggleButton" TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource AccentLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ToggleButtonForegroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="border"
                            CornerRadius="15"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--WhiteMode: PPButton-->
    <Style x:Key="PPButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            CornerRadius="15"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>